{
    "require": {
        "vlucas/phpdotenv": "^5.6.1",
        "monolog/monolog": "^3.9",
        "phpmailer/phpmailer": "^7.0.0",
        "composer/semver": "^3.4",
        "symfony/serializer-pack": "^1.3",
        "contributte/monolog": "^0.6.0"
    },
    "require-dev": {
        "phpmd/phpmd" : "@stable"
    },
    "autoload": {
        "psr-4": {
            "Game\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Game\\Tests\\": "src/Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "endroid/installer": true
        }
    }
}
